# Copy to .env and fill in your values.
# .env is gitignored — your local config won't be committed.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# To run the coach on OpenAI (or any OpenAI-compatible endpoint) instead of
# Claude, set AI_PROVIDER=openai and provide an OpenAI key. OPENAI_MODEL and
# OPENAI_BASE_URL are optional (defaults shown). Note: the coach prompts are
# tuned for Claude, so quality may vary by model.
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# WordPress companion-plugin bridge (optional — only needed when embedding the
# Agentic Coach in WordPress). Generate a strong random value and set the same
# secret in the WordPress plugin settings. Leave empty to disable the bridge.
# BRIDGE_SHARED_SECRET=
# BRIDGE_ALLOWED_SITES=https://learn.example.org
# BRIDGE_CLOCK_SKEW_SECONDS=300
# BRIDGE_CODE_TTL_SECONDS=90

# WordPress.org knowledge via Automattic's mcp-context-wporg sidecar (optional).
# When both URL and token are set, the wordpress-info plugin also pulls
# Make/WordPress-GitHub/Trac context over MCP (fail-open). See
# services/mcp-context-wporg/README.md for how to run the sidecar.
# MCP_CONTEXT_WPORG_URL=http://localhost:3001/mcp
# MCP_BEARER_TOKEN=
# MCP_SEARCH_TOOL=search
# MCP_SEARCH_ARG=query
