<?xml version="1.0"?>
<ruleset name="Agentic Coach">
	<description>WordPress Coding Standards for the Agentic Coach plugin.</description>

	<file>.</file>

	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/build/*</exclude-pattern>
	<!-- Test harness intentionally redefines WordPress functions. -->
	<exclude-pattern>/qa/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg value="sp"/>
	<arg name="colors"/>

	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>

	<config name="minimum_supported_wp_version" value="6.5"/>
	<config name="testVersion" value="7.4-"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="agentic-coach"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="agentic_coach"/>
				<element value="Agentic_Coach"/>
				<element value="AGENTIC_COACH"/>
			</property>
		</properties>
	</rule>
</ruleset>
